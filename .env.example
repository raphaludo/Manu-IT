# Senha do painel /admin (editor visual de páginas). Mínimo 8 caracteres.
CONTENT_ADMIN_SECRET=

# URL pública do site (SEO, Open Graph, sitemap). Obrigatório incluir https://
# Ex.: https://manu-it.vercel.app ou seu domínio customizado.
# Se omitir na Vercel, o build usa automaticamente VERCEL_URL em previews/produção.
NEXT_PUBLIC_SITE_URL=https://manual-itcd-pa.vercel.app

# --- Fase 2 (não utilizado na Fase 1) ---
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# OPENAI_API_KEY=
# ou outro provedor de embeddings / LLM
